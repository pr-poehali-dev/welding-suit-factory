{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Без токена — не авторизован",
      "method": "GET",
      "path": "/?entity=groups",
      "expectedStatus": 401
    },
    {
      "name": "Workers без токена — не авторизован",
      "method": "GET",
      "path": "/?entity=workers",
      "expectedStatus": 401
    },
    {
      "name": "Orders без токена — не авторизован",
      "method": "GET",
      "path": "/?entity=orders",
      "expectedStatus": 401
    },
    {
      "name": "Невалидный токен — не авторизован",
      "method": "GET",
      "path": "/?entity=groups",
      "headers": {"X-Auth-Token": "invalid-token-xyz"},
      "expectedStatus": 401
    }
  ]
}
